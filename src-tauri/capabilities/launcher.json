{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "launcher",
  "description": "Quick launcher window: list item metadata, verify master password, hand off to main",
  "windows": ["launcher"],
  "permissions": [
    "core:default",
    "core:event:allow-emit",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus"
  ]
}
